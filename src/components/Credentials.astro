---
import { credentials } from '../data/credentials';
---

<section id="credentials" class="credentials">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">Recognition</span>
      <h2>Certificates & awards</h2>
      <p>Credentials earned along the way — and a bit of recognition I'm proud of.</p>
    </div>

    <div class="cred-grid">
      {credentials.map((c) => {
        const Tag = c.file ? 'a' : 'div';
        return (
          <Tag
            class="cred-card reveal"
            style={`--accent:${c.accent}`}
            href={c.file}
            target={c.file ? '_blank' : undefined}
            rel={c.file ? 'noopener' : undefined}
          >
            <div class="cred-cover">
              {c.image ? (
                <img src={c.image} alt={`${c.title} — ${c.issuer}`} loading="lazy" />
              ) : (
                <span class="cred-emblem" aria-hidden="true">
                  {c.kind === 'award' ? '★' : '🎓'}
                </span>
              )}
              <span class="cred-kind mono">{c.kind === 'award' ? 'AWARD' : 'CERTIFICATE'}</span>
            </div>
            <div class="cred-body">
              <h3>{c.title}</h3>
              <p class="cred-issuer">{c.issuer}</p>
              <div class="cred-meta mono">
                {c.date && <span>{c.date}</span>}
                {c.credentialId && <span>ID: {c.credentialId}</span>}
              </div>
              <div class="cred-links">
                {c.file && <span class="cred-link">View ↗</span>}
                {c.verify && <a class="cred-link verify" href={c.verify} target="_blank" rel="noopener">Verify ↗</a>}
              </div>
            </div>
          </Tag>
        );
      })}
    </div>
  </div>
</section>

<style>
  .cred-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 860px) { .cred-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .cred-grid { grid-template-columns: 1fr; } }

  .cred-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
    color: inherit;
  }
  .cred-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
  }

  .cred-cover {
    position: relative;
    aspect-ratio: 16 / 10;
    background: color-mix(in srgb, var(--accent) 14%, var(--bg-card));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .cred-cover img { width: 100%; height: 100%; object-fit: cover; }
  .cred-emblem {
    font-size: 3rem;
    color: var(--accent);
    filter: drop-shadow(0 6px 14px color-mix(in srgb, var(--accent) 40%, transparent));
  }
  .cred-kind {
    position: absolute;
    top: 12px; left: 12px;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    padding: 4px 9px;
    border-radius: 999px;
    color: var(--accent);
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
  }

  .cred-body { padding: 20px 22px 22px; display: flex; flex-direction: column; flex: 1; }
  .cred-body h3 { font-size: 1.08rem; margin-bottom: 6px; line-height: 1.25; }
  .cred-issuer { font-size: 0.88rem; color: var(--ink-soft); margin-bottom: 12px; }
  .cred-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 0.72rem;
    color: var(--ink-soft);
    margin-bottom: 14px;
    margin-top: auto;
  }
  .cred-links { display: flex; gap: 14px; }
  .cred-link { font-size: 0.85rem; font-weight: 600; color: var(--accent); }
  .cred-link.verify { color: var(--ink-soft); }
  .cred-link.verify:hover { color: var(--violet); }
</style>
