---
const skills = [
  'Python', 'C#', 'VB.Net', 'JavaScript', 'SQL Server',
  'Azure', 'Google Cloud Platform', 'Git & CI/CD',
  'Prompt Engineering', 'AI-Assisted Development', 'ERP & SCM', 'Team Management',
];
---

<section id="about">
  <div class="wrap about">
    <div class="photo-wrap reveal">
      <img
        src="/assets/photo/milind.jpg"
        alt="Portrait of Milind Mishra"
        width="600"
        height="800"
        loading="lazy"
      />
      <span class="photo-badge mono">Vadodara, IN</span>
    </div>

    <div class="reveal">
      <span class="eyebrow mono">About me</span>
      <h2>Hey, I'm Milind 👋</h2>
      <p>
        I wrote code for a decade before moving into management — and never really stopped
        building. As Senior Manager at Simactricals, I lead a team spanning administration, HR,
        procurement, and finance, but I still bring the engineering directly into the work,
        building the internal tools my own team runs on.
      </p>
      <p>
        Along the way — at DXC Technology, Wipro, and MothersonSumi — I learned to bridge the gap
        between engineering and operations. That's the lens I bring now: reduce complexity, don't
        just manage it. Open to conversations at the intersection of operations, HR, and
        tech-enabled transformation.
      </p>
      <div class="skills">
        {skills.map((s) => <span>{s}</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 0.9fr 1.2fr;
    gap: 56px;
    align-items: center;
  }
  @media (max-width: 820px) { .about { grid-template-columns: 1fr; gap: 36px; } }

  .photo-wrap {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    aspect-ratio: 3 / 4;
  }
  .photo-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .photo-wrap::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(160deg, transparent 55%, rgba(108, 92, 231, 0.25));
    pointer-events: none;
  }
  .photo-badge {
    position: absolute;
    left: 14px; bottom: 14px;
    font-size: 0.72rem;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(6px);
    border: 1px solid var(--line);
    padding: 6px 12px;
    border-radius: 999px;
    z-index: 1;
  }

  .eyebrow {
    display: block;
    font-size: 0.8rem;
    color: var(--violet);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
  }
  .about h2 { font-size: clamp(1.7rem, 4vw, 2.2rem); margin-bottom: 18px; }
  .about p { color: var(--ink-soft); margin-bottom: 16px; font-size: 1.04rem; }
  .skills { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 22px; }
  .skills span {
    font-size: 0.85rem;
    font-weight: 500;
    padding: 7px 14px;
    border-radius: 999px;
    background: var(--bg-soft);
    border: 1px solid var(--line);
  }
</style>
