---
import { contact, socials, WEB3FORMS_ACCESS_KEY } from '../data/site';
import SocialIcon from './SocialIcon.astro';
---

<section id="contact" class="contact-section">
  <div class="wrap">
    <div class="contact-card reveal">
      <div class="contact-head">
        <span class="eyebrow mono">Get in touch</span>
        <h2>Let's talk operations, HR, or tech-enabled transformation.</h2>
        <p>
          Always up for a conversation on the intersection of engineering and operations —
          whether that's a role, a project, or just a good problem.
        </p>

        <div class="direct">
          <a class="direct-btn" href={`mailto:${contact.email}`}>✉&nbsp; Drop me a line</a>
          {socials.filter((s) => s.label !== 'Email').map((s) => (
            <a class="direct-btn" href={s.href} target="_blank" rel="noopener">
              <SocialIcon label={s.label} size={16} /> {s.label}
            </a>
          ))}
        </div>
      </div>

      <form id="contact-form" class="form" novalidate>
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="subject" value="New message from milindmishra.xyz" />
        <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="field">
          <input type="text" id="name" name="name" required placeholder=" " autocomplete="name" />
          <label for="name">Your name</label>
          <span class="err" data-for="name"></span>
        </div>

        <div class="field">
          <input type="email" id="email" name="email" required placeholder=" " autocomplete="email" />
          <label for="email">Email address</label>
          <span class="err" data-for="email"></span>
        </div>

        <div class="field">
          <textarea id="message" name="message" rows="4" required placeholder=" "></textarea>
          <label for="message">Message</label>
          <span class="err" data-for="message"></span>
        </div>

        <button type="submit" class="btn submit-btn">
          <span class="label">Send message</span>
          <span class="spinner" aria-hidden="true"></span>
        </button>

        <div class="success" id="form-success" hidden>
          <span class="check" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          </span>
          <div>
            <strong>Message sent!</strong>
            <p>Thanks for reaching out — I'll get back to you soon.</p>
          </div>
        </div>

        <p class="form-error" id="form-error" hidden></p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-section { padding-bottom: 40px; }
  .contact-card {
    background: var(--bg-card);
    color: var(--ink);
    border: 1px solid var(--line);
    border-radius: 28px;
    padding: 56px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
    box-shadow: var(--shadow-soft);
  }
  @media (max-width: 820px) { .contact-card { grid-template-columns: 1fr; padding: 36px 26px; gap: 32px; } }

  .contact-head .eyebrow { color: var(--violet); display: block; margin-bottom: 10px; font-size: 0.8rem; letter-spacing: 0.06em; text-transform: uppercase; }
  .contact-head h2 { color: var(--ink); font-size: clamp(1.6rem, 3.4vw, 2.2rem); }
  .contact-head > p { color: var(--ink-soft); margin-top: 14px; }

  .direct { display: flex; flex-direction: column; gap: 10px; margin-top: 26px; align-items: flex-start; }
  .direct-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 9px 16px;
    border-radius: 999px;
    border: 1.5px solid var(--line);
    color: var(--ink);
    transition: all 0.2s ease;
  }
  .direct-btn:hover { border-color: var(--violet); color: var(--violet); transform: translateX(3px); }

  /* ---- form ---- */
  .form { display: flex; flex-direction: column; gap: 20px; }
  .hp { position: absolute; left: -9999px; }

  .field { position: relative; }
  .field input, .field textarea {
    width: 100%;
    padding: 16px 16px 14px;
    border-radius: 12px;
    border: 1.5px solid var(--line);
    background: var(--bg-soft);
    color: var(--ink);
    font-family: inherit;
    font-size: 0.95rem;
    resize: vertical;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .field input:focus, .field textarea:focus { outline: none; border-color: var(--violet); background: var(--bg-card); }

  .field label {
    position: absolute;
    left: 16px; top: 15px;
    color: var(--ink-soft);
    font-size: 0.95rem;
    pointer-events: none;
    transition: all 0.18s ease;
    background: transparent;
    padding: 0 4px;
  }
  .field input:focus + label,
  .field input:not(:placeholder-shown) + label,
  .field textarea:focus + label,
  .field textarea:not(:placeholder-shown) + label {
    top: -9px;
    font-size: 0.72rem;
    color: var(--violet);
    background: var(--bg-card);
  }

  .field.invalid input, .field.invalid textarea { border-color: var(--coral); }
  .err { display: block; color: var(--coral); font-size: 0.75rem; margin-top: 6px; min-height: 1em; }

  .submit-btn {
    background: var(--violet);
    color: #fff;
    justify-content: center;
    position: relative;
  }
  .submit-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(108, 92, 231, 0.3); }
  .submit-btn.loading .label { opacity: 0; }
  .submit-btn.loading .spinner { display: block; }
  .spinner {
    display: none;
    position: absolute;
    width: 18px; height: 18px;
    border: 2.5px solid rgba(255, 255, 255, 0.4);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Success + error are hidden until the form is actually submitted.
     The [hidden] rule must win over .success's display, or it shows on load. */
  .success[hidden], .form-error[hidden] { display: none; }
  .success {
    display: flex;
    gap: 14px;
    align-items: center;
    padding: 18px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--teal) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--teal) 40%, transparent);
    animation: pop 0.4s ease;
  }
  .success .check {
    flex: none;
    width: 42px; height: 42px;
    border-radius: 50%;
    background: var(--teal);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
  }
  .success strong { color: var(--ink); }
  .success p { color: var(--ink-soft); font-size: 0.88rem; margin-top: 2px; }
  @keyframes pop { from { opacity: 0; transform: scale(0.96); } to { opacity: 1; transform: scale(1); } }

  .form-error { color: var(--coral); font-size: 0.85rem; }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successBox = document.getElementById('form-success');
  const errorBox = document.getElementById('form-error') as HTMLElement | null;
  if (form) {
    const btn = form.querySelector('.submit-btn') as HTMLButtonElement;

    const setError = (name: string, msg: string) => {
      const field = form.querySelector(`[name="${name}"]`)?.closest('.field');
      const err = form.querySelector(`.err[data-for="${name}"]`);
      if (field) field.classList.toggle('invalid', !!msg);
      if (err) err.textContent = msg;
    };

    const validate = () => {
      let ok = true;
      const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
      const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();
      if (!name) { setError('name', 'Please enter your name.'); ok = false; } else setError('name', '');
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setError('email', 'Enter a valid email address.'); ok = false; } else setError('email', '');
      if (message.length < 10) { setError('message', 'A little more detail, please (10+ chars).'); ok = false; } else setError('message', '');
      return ok;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorBox) errorBox.hidden = true;
      if (!validate()) return;

      const key = (form.elements.namedItem('access_key') as HTMLInputElement).value;
      // If no Web3Forms key configured yet, fall back to opening the user's mail client.
      if (!key || key.startsWith('REPLACE_WITH')) {
        const name = (form.elements.namedItem('name') as HTMLInputElement).value;
        const email = (form.elements.namedItem('email') as HTMLInputElement).value;
        const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value;
        window.location.href = `mailto:milind.mishra24@gmail.com?subject=${encodeURIComponent('Portfolio contact from ' + name)}&body=${encodeURIComponent(message + '\n\n— ' + name + ' (' + email + ')')}`;
        return;
      }

      btn.classList.add('loading');
      btn.disabled = true;
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(Object.fromEntries(new FormData(form))),
        });
        const data = await res.json();
        if (data.success) {
          form.querySelectorAll('.field').forEach((f) => ((f as HTMLElement).style.display = 'none'));
          btn.style.display = 'none';
          if (successBox) successBox.hidden = false;
        } else {
          throw new Error(data.message || 'Something went wrong.');
        }
      } catch (err) {
        if (errorBox) { errorBox.hidden = false; errorBox.textContent = 'Could not send right now — please email me directly at milind.mishra24@gmail.com.'; }
      } finally {
        btn.classList.remove('loading');
        btn.disabled = false;
      }
    });
  }
</script>
